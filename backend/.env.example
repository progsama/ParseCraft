# Copy this file to .env and set real values. Do not commit .env.

PORT=8080

# Comma-separated origins for browser requests (include Docker frontend port if used)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

APP_MAX_FILE_SIZE=10MB
APP_MAX_REQUEST_SIZE=10MB
APP_MAX_CHARS_FOR_AI=15000

# --- AI provider: openai | gemini ---
AI_PROVIDER=gemini
AI_BASE_URL=https://generativelanguage.googleapis.com
AI_MODEL=gemini-2.5-flash
AI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-lite-latest
AI_TEMPERATURE=0.2
# 2048 recommended for Gemini JSON + long bard summaries; 700 often truncates the summary to empty.
AI_MAX_TOKENS=2048

# Required: your API key (Gemini: Google AI Studio; OpenAI: platform dashboard)
AI_API_KEY=

# --- OpenAI example (uncomment and adjust) ---
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com
# AI_MODEL=gpt-4o-mini
# AI_FALLBACK_MODELS=
# AI_API_KEY=
